<% if @article.errors.any? %>
  <div class="form-errors">
    <h2>The following errors prevented the article from being saved</h2>
    <ul>
      <% @article.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: @article, local: true, class: "article-form") do |f| %>
  <div class="field">
    <%= f.label :title, class: "field__label" %>
    <%= f.text_field :title, class: "field__control", placeholder: "A clear, specific headline" %>
  </div>

  <div class="field">
    <%= f.label :description, class: "field__label" %>
    <%= f.text_area :description, class: "field__control field__control--textarea", rows: 8, placeholder: "Write the full article here" %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "button button--primary" %>
  </div>
<% end %>